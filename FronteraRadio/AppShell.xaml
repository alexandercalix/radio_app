<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FronteraRadio.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FronteraRadio.Views"
    xmlns:local="clr-namespace:FronteraRadio"
    Title="FronteraRadio">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Player"
        ContentTemplate="{DataTemplate views:PlayerPage}"
        Route="PlayerPage" />
</Shell>
