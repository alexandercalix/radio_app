<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="FronteraRadio.Views.UpdatePopup">
    
    <Border BackgroundColor="#1a2e3e" 
            StrokeShape="RoundRectangle 20" 
            Padding="30" 
            WidthRequest="320"
            HorizontalOptions="Center"
            VerticalOptions="Center">
        
        <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
            <Label Text="🚀" FontSize="50" HorizontalOptions="Center"/>
            <Label Text="¡Nueva Versión!" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
            <Label Text="{Binding UpdateMessage}" TextColor="#CCCCCC" HorizontalTextAlignment="Center" FontSize="14"/>
            <Button Text="ACTUALIZAR AHORA" BackgroundColor="#DD5E3B" TextColor="White" FontAttributes="Bold" HeightRequest="50" Command="{Binding UpdateCommand}"/>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>