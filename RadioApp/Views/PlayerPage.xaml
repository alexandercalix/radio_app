<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RadioApp.Views.PlayerPage"
    BackgroundColor="#0E1F2D"
    Shell.NavBarIsVisible="False">

    <Grid Padding="30">
        <VerticalStackLayout Spacing="35" VerticalOptions="Center" HorizontalOptions="Center">

            <Label
                Text="{Binding StatusText}"
                FontSize="18"
                TextColor="White"
                HorizontalOptions="Center"
                Margin="0,20,0,0"/>

            <BoxView
                HeightRequest="2"
                WidthRequest="120"
                Color="#DD5E3B"
                HorizontalOptions="Center"/>
                
        </VerticalStackLayout>
    </Grid>

</ContentPage>